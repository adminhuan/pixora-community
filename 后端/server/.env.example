NODE_ENV=development
PORT=3300
API_PREFIX=/api/v1

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_programming_community?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGINS=http://localhost:3302,http://localhost:3303

UPLOAD_DRIVER=local
UPLOAD_DIR=uploads
BASE_URL=http://localhost:3300

OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

QINIU_BUCKET=
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_DOMAIN=

SWAGGER_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

OAUTH_FRONTEND_CALLBACK_URL=http://localhost:3302/auth/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:3300/api/v1/auth/github/callback

WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=

SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_password
SMTP_FROM=your_email@qq.com
